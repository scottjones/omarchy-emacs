#!/bin/bash

# Set up Omarchy Emacs configuration for the current user

SHARE_DIR="/usr/share/omarchy-emacs"
CONFIG_DIR="$HOME/.config/emacs"
THEMED_DIR="$HOME/.config/omarchy/themed"

mkdir -p "$CONFIG_DIR/themes"
mkdir -p "$THEMED_DIR"

# Detect legacy ~/.emacs which takes precedence over ~/.config/emacs/init.el
if [[ -f "$HOME/.emacs" ]]; then
  echo "WARNING: ~/.emacs exists and will override ~/.config/emacs/init.el, preventing Omarchy integration."
  echo "If you move it, add any customizations you want to keep to ~/.config/emacs/init.el instead."
  read -r -p "Move ~/.emacs to ~/.emacs.bak? [y/N] " response
  if [[ "${response,,}" == "y" ]]; then
    mv "$HOME/.emacs" "$HOME/.emacs.bak"
    echo "Moved ~/.emacs to ~/.emacs.bak — review it and migrate any customizations to ~/.config/emacs/init.el"
  else
    echo "Skipping. Note: Omarchy theme/font integration will not work until ~/.emacs is removed or renamed."
  fi
fi

# Detect legacy ~/.emacs.d which takes precedence over ~/.config/emacs/
if [[ -d "$HOME/.emacs.d" ]]; then
  echo "WARNING: ~/.emacs.d exists and will override ~/.config/emacs/, preventing Omarchy integration."
  echo "If you move it, add any customizations you want to keep to ~/.config/emacs/init.el instead."
  read -r -p "Move ~/.emacs.d to ~/.emacs.d.bak? [y/N] " response
  if [[ "${response,,}" == "y" ]]; then
    mv "$HOME/.emacs.d" "$HOME/.emacs.d.bak"
    echo "Moved ~/.emacs.d to ~/.emacs.d.bak — review it and migrate any customizations to ~/.config/emacs/init.el"
  else
    echo "Skipping. Note: Omarchy theme/font integration will not work until ~/.emacs.d is removed or renamed."
  fi
fi

# Copy config files (don't overwrite existing user customizations)
for file in init.el shell-bashrc; do
  if [[ ! -f "$CONFIG_DIR/$file" ]]; then
    cp "$SHARE_DIR/config/$file" "$CONFIG_DIR/$file"
  fi
done

for file in omarchy-dark-theme.el omarchy-light-theme.el; do
  if [[ ! -f "$CONFIG_DIR/themes/$file" ]]; then
    cp "$SHARE_DIR/config/themes/$file" "$CONFIG_DIR/themes/$file"
  fi
done

# Install font-set hook to sync Emacs font on font changes
HOOKS_DIR="$HOME/.config/omarchy/hooks"
mkdir -p "$HOOKS_DIR"
if [[ ! -f "$HOOKS_DIR/font-set" ]]; then
  cp "$SHARE_DIR/hooks/font-set" "$HOOKS_DIR/font-set"
  chmod +x "$HOOKS_DIR/font-set"
else
  echo "Note: ~/.config/omarchy/hooks/font-set already exists — add 'omarchy-restart-emacs' to it to sync Emacs on font changes."
fi

# Install the color template
if [[ ! -f "$THEMED_DIR/omarchy-colors.el.tpl" ]]; then
  cp "$SHARE_DIR/omarchy-colors.el.tpl" "$THEMED_DIR/"
fi

# Generate colors for the current theme
if command -v omarchy-theme-set &>/dev/null; then
  theme=$(cat "$HOME/.config/omarchy/current/theme.name" 2>/dev/null)
  if [[ -n $theme ]]; then
    omarchy-theme-set "$theme"
  fi
fi

echo "Omarchy Emacs setup complete!"
